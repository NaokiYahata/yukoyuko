# OS / editor
.DS_Store
Thumbs.db
*.swp

# Obsidian の設定はすべて個人ローカル扱い（git管理しない）
.obsidian/

# 環境ローカル
.env

# 元データ（バイナリ原本）はgit管理しない。
# pptx/pdf/xlsx/docx 等は抽出した markdown のみを raw/ にコミットする。
raw/_originals/*
!raw/_originals/.gitkeep
raw/**/*.pdf
raw/**/*.ppt
raw/**/*.pptx
raw/**/*.xls
raw/**/*.xlsx
raw/**/*.doc
raw/**/*.docx
raw/**/*.key
raw/**/*.numbers
raw/**/*.pages
