# OS / editor
.DS_Store
Thumbs.db
*.swp

# Obsidian の設定一式（git管理対象外）
.obsidian/

# 環境ローカル
.env

# 元データ（バイナリ原本）はgit管理しない。
# pptx/pdf/xlsx/docx 等は抽出した markdown のみを raw/ にコミットする。
raw/_originals/*
!raw/_originals/.gitkeep
raw/**/*.pdf
raw/**/*.ppt
raw/**/*.pptx
raw/**/*.xls
raw/**/*.xlsx
raw/**/*.doc
raw/**/*.docx
raw/**/*.key
raw/**/*.numbers
raw/**/*.pages

# ローカル生成成果物（AIが会話中に生成する git 管理不要の成果物）。
# .gitkeep のみ追跡し、配下の中身はコミットしない。
local_outputs/*
!local_outputs/.gitkeep
